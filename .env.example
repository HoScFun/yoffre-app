# Clé publique (anon) Supabase — sûre à exposer côté client, protégée par RLS
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# URL canonique du site (SEO, sitemap, liens emails)
NEXT_PUBLIC_SITE_URL=https://yoffre.fr

# --- Analytics (désactivé par défaut — laisser vide tant qu'on n'active pas) ---
# Fournisseur souverain : "matomo" (FR) ou "plausible" (UE). Vide = aucun tracking.
NEXT_PUBLIC_ANALYTICS_PROVIDER=
# Si matomo :
NEXT_PUBLIC_MATOMO_URL=
NEXT_PUBLIC_MATOMO_SITE_ID=
# Si plausible :
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=
